# Supabase project URL (from Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (from Supabase dashboard → Settings → API)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# LLM provider API key (OpenAI-compatible)
VITE_LLM_API_KEY=your-llm-api-key

# LLM provider base URL (OpenAI-compatible endpoint, e.g. https://api.openai.com/v1)
VITE_LLM_API_URL=https://api.openai.com/v1
